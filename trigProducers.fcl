# -*- mode: tcl -*-
#------------------------------------------------------------------------------
# this file includes all the prolog needed to run the reconstruction
# at the trigger level and the filters used to make the trigger decision
#------------------------------------------------------------------------------
BEGIN_PROLOG
TrigProducers : {
   producers : 

   {

      #
      artFragFromDTCEvents: {
         diagLevel: 0
         makeCRVFrag: 0
         makeCaloFrag: 1
         makeSTMFrag: 0
         makeTrkFrag: 1
         module_type: "ArtFragmentsFromDTCEvents"
      }
      CaloClusterFast: {
            caloTag: "daq:calo"
            caphriEDepMax: 5
            caphriEDepMin: 1
            deltaTPulses: 5
            diagLevel: 0
            digiSampling: 5
            hitEDepMax: 1000
            hitEDepMin: 1
            module_type: "CaloHitsFromFragments"
            nPEperMeV: 30
            nSigmaNoise: 4
            noiseLevelMeV: 5.5e-1
      }
      TTmakeSH: {
         diagLevel: 0
         module_type: "StrawRecoFromFragments"
         trkTag: "daq:trk"
         useTrkADC: 0
      }
      #

      CaloClusterFastFromDigi: {
         EminSeed: 10
         EnoiseCut: 1
         ExpandCut: 1
         caloHitCollection: "CaloHitMakerFast:calo"
         deltaTime: 10
         diagLevel: 0
         extendSearch: true
         minSiPMPerHit: 2
         module_label: "CaloClusterFast"
         module_type: "CaloClusterFast"
         timeOffset: -61
      }
      CaloHitMakerFast: {
         ProtonBunchTimeTag: "EWMProducer"
         caloDigiCollection: "CaloDigiMaker"
         caphriCrystalID: [
            623,
            624,
            595,
            596
         ]
         deltaTPulses: 11
         diagLevel: 0
         digiSampling: 5
         module_label: "CaloHitMakerFast"
         module_type: "CaloHitMakerFast"
         nPEperMeV: 30
         nSigmaNoise: 4
         noiseLevelMeV: 5.5e-1
      }
      CstCosmicTrackFinder: {
         ComboHitCollection: "TTmakePH"
         CosmicTrackFit: {
            DoNotUseFlag: "Outlier"
            GaussianSeedTimeResolution: 24
            MaxDOCA: 2.5
            MaxDeltaChi2: 1e-3
            MaxHitPullForSeed: 100
            MaxLogL: 150
            MaxPosDev: 200
            MaxSeedChi2DOF: 2.5
            MaxTimeResidual: 40
            MaxTrackLength: 2000
            NParameters: 4
            Noutliers: 2
            UseTSeedDirection: false
            maxNiter: 1000
            minNComboHits: 8
            minNHitsTimeCluster: 0
            minNStrawHits: 2
         }
         DoDrift: true
         DriftRes: 10
         LineFinderTag: "CstLineFinder"
         MinuitPrecision: -1
         MinuitTolerance: 5e-1
         TimeClusterCollection: "CstSimpleTimeCluster"
         UseChiFit: false
         UseLineFinder: true
         UseTime: true
         minNComboHits: 0
         minNHitsTimeCluster: 0
         minNStrawHits: 4
         module_label: "CstCosmicTrackFinder"
         module_type: "CosmicTrackFinder"
      }
      CstLineFinder: {
         ComboHitCollection: "TTmakePH"
         NSteps: 0
         NTSteps: 0
         StepSize: 5e-1
         TimeClusterCollection: "CstSimpleTimeCluster"
         maxDOCA: 10
         minPeak: 10
         module_label: "CstLineFinder"
         module_type: "LineFinder"
         t0offset: 0
      }
      CstSimpleTimeCluster: {
         ComboHitCollection: "TTmakePH"
         TestFlag: false
         module_label: "CstSimpleTimeCluster"
         module_type: "SimpleTimeCluster"
      }
      TTCalHelixMergerDeM: {
         HelixFinders: [
            "TTCalHelixFinderDe:Positive"
         ]
         debugLevel: 0
         deltanh: 5
         module_label: "TTCalHelixMergerDeM"
         module_type: "MergeHelices"
         scaleXY: 1.1
         scaleZPhi: 7.5e-1
      }
      TTCalHelixMergerDeP: {
