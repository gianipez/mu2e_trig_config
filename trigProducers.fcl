            MaterialCorrection: true
            MaxCaloClusterDOCA: 150
            MaxCaloClusterDt: 10
            MaxDStraw: 2
            MaxStrawDOCA: 5
            MaxStrawDOCAConsistency: 1
            MaxStrawHitDOCA: 10
            MaxStrawHitDt: 50
            MinCaloClusterEnergy: 10
            PrintLevel: 0
            SampleSurfaces: [
               "TT_Mid"
            ]
            SampleTimeBuffer: 10
            StrawHitClusterDeltaStraw: 3
            StrawHitClusterDeltaT: 1
            StrawHitClusterLevel: "none"
            TPOCAPrecision: 1e-4
            UseCaloCluster: true
